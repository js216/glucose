# test/ IS in the lint gate (see the Makefile `tidy` target): these files decide
# whether every other check means anything, so they get the SAME checks as src/
# via InheritParentConfig. This file only turns OFF the handful that are wrong
# for a HOSTED TEST HARNESS specifically -- not one real defect is silenced, and
# each disable is justified below. Anything fixable at the source was fixed, not
# suppressed.
#
#   - misc-use-internal-linkage: every test binary links the real production .c
#     files, and each test supplies stub definitions of the symbols those files
#     reference (__android_log_print, plot_set_max). Those stubs MUST have
#     external linkage -- making them static is not a style nit, it breaks the
#     link (verified: the build fails). main() is not affected (the check knows
#     it is an entry point); only the cross-TU stubs trip it.
#   - cert-err33-c: the harnesses write PPM renders and CSV fixtures to files in
#     tmp/ and print diagnostics to stdout. Return-checking each fprintf / fwrite
#     / fputs / fclose / snprintf here would be pure noise -- it tests the
#     harness's own I/O, not the code under test, and is not how test fixtures
#     are written. Production code (src/) keeps this check.
#   - readability-function-size / hicpp-function-size (alias): each test main() is
#     an intentionally long, flat sequence of independent assertions. Splitting it
#     to satisfy a line-count heuristic would scatter one suite across helpers and
#     read worse, not better.
InheritParentConfig: true
Checks: >
  -misc-use-internal-linkage,
  -cert-err33-c,
  -readability-function-size,
  -hicpp-function-size
