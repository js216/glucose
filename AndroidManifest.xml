<?xml version="1.0" encoding="utf-8"?>
<!-- SPDX-License-Identifier: GPL-3.0 -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          package="com.jk.stealo"
          android:versionCode="1" android:versionName="1.0">
  <uses-sdk android:minSdkVersion="29" android:targetSdkVersion="34"/>

  <!-- Android 12+ (API 31+): scanning never used to derive location -->
  <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
                   android:usesPermissionFlags="neverForLocation"/>
  <uses-permission android:name="android.permission.BLUETOOTH_CONNECT"/>
  <!-- pre-12 devices: legacy equivalents -->
  <uses-permission android:name="android.permission.BLUETOOTH"
                   android:maxSdkVersion="30"/>
  <uses-permission android:name="android.permission.BLUETOOTH_ADMIN"
                   android:maxSdkVersion="30"/>
  <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"
                   android:maxSdkVersion="30"/>
  <!-- keep BLE alive in the background via a foreground service -->
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE"/>
  <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
  <uses-permission android:name="android.permission.VIBRATE"/>
  <uses-permission android:name="android.permission.WAKE_LOCK"/>
  <!-- keep the process alive through Doze (user grants via the system dialog) -->
  <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"/>

  <!-- debuggable is intentionally absent (defaults to false = release-safe).
       Dev builds flip it on via aapt's debug-mode flag so crash.log is
       retrievable on-device; `make release` does not. -->
  <application android:label="Stealo"
               android:icon="@mipmap/ic_launcher"
               android:roundIcon="@mipmap/ic_launcher_round"
               android:allowBackup="false"
               android:theme="@android:style/Theme.NoTitleBar">
    <activity android:name="android.app.NativeActivity" android:exported="true"
              android:configChanges="orientation|screenSize|screenLayout|keyboardHidden">
      <meta-data android:name="android.app.lib_name" android:value="stealo"/>
      <intent-filter>
        <action android:name="android.intent.action.MAIN"/>
        <category android:name="android.intent.category.LAUNCHER"/>
      </intent-filter>
    </activity>
    <service android:name=".StealoService"
             android:foregroundServiceType="connectedDevice"
             android:exported="false"/>
    <!-- serves the exported CSVs as content:// URIs for the EXPORT DATA share -->
    <provider android:name=".StealoFiles"
              android:authorities="com.jk.stealo.files"
              android:exported="false"
              android:grantUriPermissions="true"/>
  </application>
</manifest>
